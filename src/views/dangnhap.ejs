<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Document</title>
	<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css" integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm" crossorigin="anonymous">
	<script src="https://code.jquery.com/jquery-3.2.1.slim.min.js" integrity="sha384-KJ3o2DKtIkvYIK3UENzmM7KCkRr/rE9/Qpg6aAZGJwFDMVNA/GpGFF93hXpG5KkN" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/popper.js@1.12.9/dist/umd/popper.min.js" integrity="sha384-ApNbgh9B+Y1QKtv3Rn7W3mgPxhU9K/ScQsAP7hUibX39j7fakFPskvXusvfa0b4Q" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/js/bootstrap.min.js" integrity="sha384-JZR6Spejh4U02d8jOt6vLEHfe/JQGiRRSQQxSfFWpi1MquVdAyjUar5+76PVCmYl" crossorigin="anonymous"></script>
</head>
<body>
	<div class="conteiner" style="margin-top: 100px;">
		<div class="row justify-content-center">
			<form action="/postdangnhap" method="post">
				
				<div class="form-group">
				  <label for="exampleInputEmail1">Số điện thoại</label>
				  <input type="number" class="form-control" name="phone" aria-describedby="emailHelp" placeholder="Nhập số điện thoại">
				  <small id="emailHelp" class="form-text text-muted">Số điện thoại đã dùng để đăng ký tài khoản </small>
				</div>
				<div class="form-group">
				  <label for="exampleInputPassword1">Mật khẩu</label>
				  <input type="password" class="form-control" name="password" placeholder="Điền mật khẩu">
				</div>
				<div class="form-row">
					<div class="form-group col-md-5">
						
						<button 
						type="submit" 
						class="btn btn-primary" 
						style="margin-top: 32px;"
						>Đăng nhập 
						</button>
					</div>
					
					<div class="form-group col-md-7">
					<label for="inputgender">Bạn là ?</label>
					<select name="mod" class="form-control"
					style="cursor: pointer;">
						<option value = 2>Bệnh nhân</option>
						
						<option value = 1>Bác sĩ</option>
						<option value = 0>Quản trị viên</option>
					</select>
					</div>
				</div>
				<a href="/dangky" > Chưa có tài khoản ?</a>
			  
			</form>
		</div>
	</div>
	<style>
		/* Ẩn mũi tên tăng giảm của số điện thoại */
		input[type="number"]::-webkit-inner-spin-button,
		input[type="number"]::-webkit-outer-spin-button {
		  -webkit-appearance: none;
		  margin: 0;
		}
	  </style>
</body>
</html>